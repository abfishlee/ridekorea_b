# Copy to .env and fill in. Values prefixed EXPO_PUBLIC_ are exposed to the app bundle.
# (Anon/publishable key + URL are safe to ship; RLS protects the data. Never put the service-role/secret key here.)

# --- Supabase ---
# Local dev defaults. Get the anon/publishable key from `supabase status`.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=__fill_from_supabase_status__

# --- Naver Map (네가 발급: NAVER Cloud Platform > Maps) — Phase 4에서 사용 ---
EXPO_PUBLIC_NAVER_MAP_CLIENT_ID=__your_ncp_maps_client_id__

# --- Google OAuth ---
# 앱에는 client ID가 필요 없음(브라우저 OAuth 플로우). 구글 OAuth 클라이언트(Web)는
# Supabase에서 설정한다:
#   • 클라우드(대시보드): Authentication > Providers > Google 에 client ID/secret 입력
#   • 로컬: supabase/config.toml 의 [auth.external.google] enabled=true + client_id/secret(env)
# Apple은 상용화 시점에 추가(Apple Developer 연 $99).
