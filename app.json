{
  "expo": {
    "name": "RideKorea",
    "slug": "ridekorea",
    "scheme": "ridekorea",
    "icon": "./brand_assets/app_icon_512x512.png",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./brand_assets/naturecode_logo_transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDFBF7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "kr.oceanit.ridekorea",
      "infoPlist": {
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "package": "kr.oceanit.ridekorea",
      "adaptiveIcon": {
        "foregroundImage": "./brand_assets/app_icon_512x512.png",
        "backgroundColor": "#FDFBF7"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./brand_assets/favicon_64x64.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "RideKorea uses your location to record your journey and surprise you with local rewards.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-status-bar",
      "expo-splash-screen",
      "expo-localization",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "cameraPermission": "RideKorea uses your camera to pin photos to your journey.",
          "photosPermission": "RideKorea accesses your photos so you can add them to your journey."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
